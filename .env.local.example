# ============================================================
# PRODUCTION: Variables marked [Vercel] go in Vercel dashboard.
# All other secrets live as Login items in the Vaultwarden
# collection and are loaded at runtime via instrumentation.ts.
#
# DEVELOPMENT: Set all variables below in .env.local.
# If Vaultwarden vars are not configured, secrets fall back to
# the values set directly in .env.local.
# ============================================================

# [Vercel] Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tum2026?schema=public"

# [Vercel] NextAuth — required in Edge runtime for JWT signing
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# [Vercel] Azure App ID + Tenant ID (non-sensitive — needed by Edge middleware)
AUTH_MICROSOFT_ENTRA_ID_ID="your-azure-sso-client-id"
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="your-azure-tenant-id"

# [Vercel] Vaultwarden bootstrap credentials
# User API Key: found in Vaultwarden → Account Settings → Security → API Key
VAULTWARDEN_URL="https://pwd.ardepa.site"
VAULTWARDEN_CLIENT_ID="user.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
VAULTWARDEN_CLIENT_SECRET="your-api-key-client-secret"
VAULTWARDEN_MASTER_PASSWORD="your-vault-master-password"
VAULTWARDEN_COLLECTION_ID="e66aa257-debf-4d09-bfbc-155f94a0726e"

# ============================================================
# The variables below are loaded from Vaultwarden in production.
# In development (no Vaultwarden), set them here directly.
# Vault item: Login, Name = env var key, Password = secret value.
# ============================================================

# Microsoft Entra ID SSO — client secret (SENSITIVE)
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-azure-sso-client-secret"

# Microsoft Graph API
GRAPH_CLIENT_ID="your-graph-app-client-id"
GRAPH_CLIENT_SECRET="your-graph-app-client-secret"

# NinjaOne RMM API
NINJA_CLIENT_ID="your-ninja-client-id"
NINJA_CLIENT_SECRET="your-ninja-client-secret"

# Sophos Central Partner API
SOPHOS_CLIENT_ID="your-sophos-partner-client-id"
SOPHOS_CLIENT_SECRET="your-sophos-partner-client-secret"

# ============================================================
# Non-secret config
# ============================================================
TECHNICIAN_SYNC_TENANT_ID="10"
TECHNICIAN_SYNC_GROUP_NAME="TUM APP"

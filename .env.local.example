# ============================================================
# PRODUCTION: Only the variables marked [Vercel] need to be
# set in Vercel's environment variables dashboard.
# All other secrets are loaded at runtime from Vaultwarden.
#
# DEVELOPMENT: Set all variables below in .env.local.
# If VAULTWARDEN_URL/ACCESS_TOKEN are not set, the app falls
# back to reading secrets directly from .env.local.
# ============================================================

# [Vercel] Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tum2026?schema=public"

# [Vercel] NextAuth — AUTH_SECRET is required in Edge runtime for JWT signing
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# [Vercel] Microsoft Entra ID — App ID and Tenant ID are non-sensitive (public)
# AUTH_MICROSOFT_ENTRA_ID_ID and AUTH_MICROSOFT_ENTRA_ID_TENANT_ID stay in Vercel
# because they are needed by the Edge middleware for OAuth provider initialization.
AUTH_MICROSOFT_ENTRA_ID_ID="your-azure-sso-client-id"
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="your-azure-tenant-id"

# [Vercel] Vaultwarden bootstrap credentials — required for instrumentation.ts
# to authenticate with Vaultwarden and load all other secrets at startup.
VAULTWARDEN_URL="https://your-vaultwarden-instance.com"
VAULTWARDEN_ACCESS_TOKEN="your-service-account-access-token"

# ============================================================
# The variables below are loaded from Vaultwarden in production.
# In development (no Vaultwarden configured), set them here.
# ============================================================

# Microsoft Entra ID — SSO App client secret (SENSITIVE)
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-azure-sso-client-secret"

# Microsoft Graph API — Multi-tenant Enterprise App (client credentials)
GRAPH_CLIENT_ID="your-graph-app-client-id"
GRAPH_CLIENT_SECRET="your-graph-app-client-secret"

# NinjaOne RMM API
NINJA_CLIENT_ID="your-ninja-client-id"
NINJA_CLIENT_SECRET="your-ninja-client-secret"

# Sophos Central Partner API
SOPHOS_CLIENT_ID="your-sophos-partner-client-id"
SOPHOS_CLIENT_SECRET="your-sophos-partner-client-secret"

# ============================================================
# Non-secret config (stays in Vercel env vars)
# ============================================================

# Technician Sync (from Microsoft 365 group)
TECHNICIAN_SYNC_TENANT_ID="10"
TECHNICIAN_SYNC_GROUP_NAME="TUM APP"
